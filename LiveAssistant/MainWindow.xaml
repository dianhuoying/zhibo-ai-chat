<Window x:Class="LiveAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="智播助聊"
        Height="680" Width="380"
        MinHeight="500" MinWidth="320"
        WindowStyle="None"
        Background="#0A0E17"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        StateChanged="Window_StateChanged">

    <Border
            CornerRadius="12"
            Background="#0A0E17"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Rectangle Fill="Transparent" Cursor="Hand"
                       MouseLeftButtonDown="DragBar_MouseLeftButtonDown" />
            <wv2:WebView2 Grid.Row="1" x:Name="webView" DefaultBackgroundColor="#0A0E17" />
        </Grid>
    </Border>
</Window>